if ! command -v pass >/dev/null 2>&1; then
    echo "pass is required for Maven Central publishing env vars" >&2
    return 0
fi

maven_central_username="$(pass show maven-central-username 2>/dev/null | sed -n '1p')"
maven_central_password="$(pass show maven-central-password 2>/dev/null | sed -n '1p')"

if [ -z "$maven_central_username" ] || [ -z "$maven_central_password" ]; then
    echo "pass entries maven-central-username and maven-central-password are required for Maven Central publishing" >&2
    unset maven_central_username maven_central_password
    return 0
fi

export ORG_GRADLE_PROJECT_mavenCentralUsername="$maven_central_username"
export ORG_GRADLE_PROJECT_mavenCentralPassword="$maven_central_password"

unset maven_central_username maven_central_password

# Snapshots do not require signing. Set this to 1 before entering the repo
# when you want direnv to export in-memory GPG signing variables as well.
if [ "${NWC_KMP_ENABLE_SIGNING:-0}" = "1" ]; then
    nwc_kmp_signing_key_id="57C36EB1D0D4ECF3"
    export ORG_GRADLE_PROJECT_signingInMemoryKeyId="$nwc_kmp_signing_key_id"
    export ORG_GRADLE_PROJECT_signingInMemoryKey="$(gpg --export-secret-keys --armor "$nwc_kmp_signing_key_id" 2>/dev/null)"

    nwc_kmp_signing_password="$(pass show maven-central-signing-password 2>/dev/null | sed -n '1p')"
    if [ -n "$nwc_kmp_signing_password" ]; then
        export ORG_GRADLE_PROJECT_signingInMemoryKeyPassword="$nwc_kmp_signing_password"
    fi

    unset nwc_kmp_signing_key_id nwc_kmp_signing_password
fi
